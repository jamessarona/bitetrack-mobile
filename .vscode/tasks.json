{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Android Emulator (Pixel 6a)",
      "type": "shell",
      "command": "${env:ANDROID_HOME}\\emulator\\emulator.exe",
      "args": ["-avd", "Pixel_6a_API_35"],
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Flutter: pub get",
      "type": "shell",
      "command": "flutter",
      "args": ["pub", "get"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Flutter: build_runner",
      "type": "shell",
      "command": "dart",
      "args": ["run", "build_runner", "build", "--delete-conflicting-outputs"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}
